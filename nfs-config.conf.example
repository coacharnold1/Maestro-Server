# NFS Server Configuration for Maestro
# This file is automatically generated during installation
# Location: /etc/maestro/nfs-config.conf
#
# The NFS health check scripts (nfs-health-check.sh, nfs-health-report.sh)
# will use the NFS_SERVER IP below to monitor connectivity.
#
# Configuration Priority:
# 1. /etc/maestro/nfs-config.conf (if exists, use this)
# 2. Auto-detect from /etc/fstab (extract first NFS mount IP)
# 3. Fallback to 192.168.1.130 (hardcoded default)
#
# IMPORTANT: If you change your NFS server IP or move to a different server:
# - Update /etc/fstab with new NFS server mounts
# - Update this file with the new NFS_SERVER IP
# - Restart the NFS health check timer: sudo systemctl restart nfs-health-check.timer
#

# NFS Server IP Address
# This should match the IP in your /etc/fstab mount entries
NFS_SERVER="192.168.1.130"
